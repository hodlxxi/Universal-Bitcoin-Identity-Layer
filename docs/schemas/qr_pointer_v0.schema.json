{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hodlxxi.com/schemas/qr_pointer_v0.schema.json",
  "title": "HODLXXI QR Pointer v0",
  "description": "Documentation-only schema contract for a bounded discovery pointer. A QR Pointer does not grant authority, prove consent, or create runtime side effects.",
  "type": "object",
  "required": [
    "schema",
    "pointer_id",
    "target_path",
    "target_class",
    "created_at",
    "non_claims",
    "privacy_class",
    "lifecycle"
  ],
  "properties": {
    "schema": {
      "const": "hodlxxi.qr_pointer.v0"
    },
    "pointer_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]*$"
    },
    "target_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^/[^?#]*$",
      "description": "Relative HODLXXI runtime path only; no scheme, host, query string, fragment, or third-party redirect URL."
    },
    "target_class": {
      "type": "string",
      "enum": [
        "agent_discovery",
        "operator_discovery",
        "capability_discovery",
        "receipt_verification",
        "job_status_discovery",
        "attestation_discovery",
        "trust_event_discovery",
        "reputation_discovery",
        "chain_health_discovery",
        "marketplace_discovery",
        "skills_discovery",
        "delegation_discovery",
        "request_discovery"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "revocation_status": {
      "type": "string",
      "enum": ["active", "revoked", "expired"]
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "contains": {
        "const": "does_not_prove_identity"
      },
      "items": {
        "type": "string",
        "enum": [
          "does_not_prove_identity",
          "does_not_prove_human_identity",
          "does_not_prove_consent",
          "does_not_prove_approval",
          "does_not_prove_delegation",
          "does_not_prove_authorization",
          "does_not_prove_execution",
          "does_not_prove_receipt_validity",
          "does_not_prove_payment",
          "does_not_prove_satisfaction",
          "does_not_create_obligation",
          "does_not_prove_trust",
          "does_not_prove_reputation",
          "does_not_prove_human_presence",
          "does_not_prove_operator_approval",
          "does_not_prove_printed_code_integrity",
          "does_not_prove_third_party_qr_provider_trustworthiness",
          "is_not_an_audit_log"
        ]
      }
    },
    "privacy_class": {
      "type": "string",
      "enum": ["public", "pseudonymous", "sensitive"]
    },
    "lifecycle": {
      "type": "object",
      "required": ["scan_side_effects", "replay_safe", "copy_safe"],
      "properties": {
        "scan_side_effects": {
          "const": "none"
        },
        "replay_safe": {
          "const": true
        },
        "copy_safe": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "signature": {
      "type": "string",
      "description": "Optional future signature over canonical JSON. Not required for the docs-only/schema-only phase."
    }
  },
  "additionalProperties": false
}
